# ========================================
# 环境变量配置模板
# ========================================
# 使用说明：
# 1. 复制本文件并重命名为 .env
# 2. 填写实际的配置值
# 3. .env 文件不会被提交到 Git（已在 .gitignore 中）
# ========================================

# ==================== API 配置 ====================
# DeepSeek API Key（必填）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# HuggingFace 镜像源（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ==================== 数据库配置 ====================
# MySQL 配置
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=adaptive_eval

# Redis 配置（可选，用于缓存加速）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ==================== 应用配置 ====================
# 项目名称
PROJECT_NAME=自适应测评系统

# 应用版本
VERSION=1.0.0

# 运行端口
APP_PORT=8088

# 单个教师资料上传大小限制（MB）
MAX_UPLOAD_SIZE_MB=200

# 调试模式（开发环境设为 True，生产环境设为 False）
DEBUG=True

# ==================== 安全配置 ====================
# JWT 密钥（用于生成 Token，请修改为随机字符串）
SECRET_KEY=your-secret-key-change-this-in-production

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== RAG 配置 ====================
# Embedding 模型
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Reranker 模型
RERANKER_MODEL=BAAI/bge-reranker-base

# 向量库路径
FAISS_INDEX_PATH=data/faiss_index

# 文档路径
DOCS_PATH=data/docs

# RAGAS 正式评测默认样本数；当前会从正式集文件中截取前 N 条参与评测
RAG_EVAL_FORMAL_SIZE=30

# ==================== LLM 配置 ====================
# 模型名称
LLM_MODEL=deepseek-chat

# Temperature（控制输出随机性，0-1）
LLM_TEMPERATURE=0.7

# 最大生成长度
LLM_MAX_TOKENS=2000

# ==================== 其他配置 ====================
# 代理设置（如果需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,0.0.0.0

# ==================== Logging and Task Recovery ====================
# Reduce third-party SDK log noise by default. Set to INFO for troubleshooting.
THIRD_PARTY_LOG_LEVEL=WARNING

# Set to true when you want detailed OpenAI/DeepSeek/httpx request logs.
VERBOSE_LLM_LOGS=false

# Startup task recovery policy.
# Leave queued/retrying tasks for manual inspection by default.
TASK_RECOVER_QUEUED_ON_START=false
TASK_RECOVER_RETRYING_ON_START=false

# ==================== RAGAS Network Stability ====================
# Lower these when your network is unstable or the model provider is flaky.
RAGAS_LLM_TIMEOUT_SEC=60
RAGAS_LLM_MAX_RETRIES=6
RAGAS_MAX_WORKERS=2
RAGAS_SAMPLE_CONCURRENCY=1
RAGAS_HTTP_MAX_CONNECTIONS=8
RAGAS_HTTP_KEEPALIVE_CONNECTIONS=4

